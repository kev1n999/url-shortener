generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id Int @id @default(autoincrement())
  email String @unique 
  name String
  password String
  createdat DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shortener {
  id Int @id @default(autoincrement())
  shortCode String @unique 
  originalurl String 
  createdAt DateTime @default(now())
}